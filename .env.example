# DexRay Configuration
# Copy this file to .env and customize as needed

# Application Settings
APK_APP_NAME=DexRay
APK_DEBUG=false
APK_LOG_LEVEL=INFO

# Directories
APK_UPLOAD_DIR=/tmp/apk-analyzer/uploads
APK_OUTPUT_DIR=/tmp/apk-analyzer/reports
APK_TEMP_DIR=/tmp/apk-analyzer/temp

# Upload Limits
APK_MAX_UPLOAD_SIZE=524288000

# Server Configuration
APK_SERVER_HOST=0.0.0.0
APK_SERVER_PORT=8000
APK_SERVER_WORKERS=4

# External Tools (set to false to disable)
APK_ENABLE_JADX=true
APK_ENABLE_APKTOOL=true
APK_ENABLE_ANDROGUARD=true

# Report Settings
APK_REPORT_TITLE=APK Security Analysis Report
APK_REPORT_COMPANY_NAME=APK Analyzer
